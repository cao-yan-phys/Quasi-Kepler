Notebook[{
Cell["QK vs Direct EOM", "Title",ExpressionUUID->"d502abf3-4302-034a-9b10-c4bb94a838dd"],

Cell["\<\
Run Setup once. Edit the Global Inputs cell and the input cell at the start \
of each orbit section. Each section first returns the completed initial data, \
initial scales, conserved labels, and QK parameters, then computes QK and \
direct EOM trajectories with t, r, phi, rdot, phidot. Units are G=c=M=1, so \
plot axes use t/M, r/M, and M phidot. In all plots the red curve labelled 0PN \
QK is the Newtonian QK trajectory generated from the same initial data. In \
overlay plots the direct-EOM curve is drawn first and the black dashed QK \
curve is drawn second.\
\>", "Text",ExpressionUUID->"b6412b70-dc0d-7548-94b4-574336907fa2"],

Cell[CellGroupData[{

Cell["Setup", "Section",ExpressionUUID->"6c005209-ed17-d045-8546-a96992e5c5f5"],

Cell[BoxData[
 RowBox[{
  RowBox[{"ClearAll", "[", "\"\<Global`*\>\"", "]"}], ";", 
  RowBox[{"root", "=", 
   RowBox[{"ParentDirectory", "[", 
    RowBox[{"NotebookDirectory", "[", "]"}], "]"}]}], ";", 
  RowBox[{"Get", "[", 
   RowBox[{"FileNameJoin", "[", 
    RowBox[{"{", 
     RowBox[{"root", ",", "\"\<src\>\"", ",", "\"\<QKOrbits.wl\>\""}], "}"}], 
    "]"}], "]"}], ";", 
  RowBox[{"Get", "[", 
   RowBox[{"FileNameJoin", "[", 
    RowBox[{"{", 
     RowBox[{"root", ",", "\"\<src\>\"", ",", "\"\<DirectEOMOrbits.wl\>\""}], 
     "}"}], "]"}], "]"}], ";", 
  RowBox[{"eom", "=", 
   RowBox[{"DirectEOMOrbits`DirectEOMLoad", "[", 
    RowBox[{"\"\<RootDirectory\>\"", "\[Rule]", "root"}], "]"}]}], ";", 
  RowBox[{"ClearAll", "[", 
   RowBox[{
   "makeTimes", ",", "cleanInitialData", ",", "computeQKInfo", ",", 
    "computeQKPN", ",", "computeQK", ",", "computeDirect", ",", "orbitRows", 
    ",", "realValues", ",", "shortValue", ",", "shortAssoc", ",", 
    "publicQKParameterKeys", ",", "qkInfoDisplay", ",", "styleFor", ",", 
    "seriesPanel", ",", "plotOrbit", ",", "exportOrbit"}], "]"}], ";", 
  RowBox[{
   RowBox[{"makeTimes", "[", 
    RowBox[{"tStart_", ",", "tEnd_", ",", "samples_"}], "]"}], ":=", 
   RowBox[{"N", "[", 
    RowBox[{
     RowBox[{"Subdivide", "[", 
      RowBox[{"tStart", ",", "tEnd", ",", "samples"}], "]"}], ",", "wp"}], 
    "]"}]}], ";", 
  RowBox[{
   RowBox[{"cleanInitialData", "[", "data_Association", "]"}], ":=", 
   RowBox[{"AssociationMap", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"N", "[", 
       RowBox[{"#1", ",", "wp"}], "]"}], "&"}], ",", "data"}], "]"}]}], ";", 
  RowBox[{
   RowBox[{"computeQKInfo", "[", 
    RowBox[{"modelName_String", ",", "initialData_Association"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "model", "}"}], ",", 
     RowBox[{
      RowBox[{"model", "=", 
       RowBox[{"QKOrbits`QKLoadModel", "[", 
        RowBox[{"modelName", ",", 
         RowBox[{"\"\<RootDirectory\>\"", "\[Rule]", "root"}]}], "]"}]}], ";", 
      RowBox[{"QKOrbits`QKParameterValuesFromInitialData", "[", 
       RowBox[{"model", ",", "primitiveParams", ",", "initialData", ",", 
        RowBox[{"WorkingPrecision", "\[Rule]", "wp"}], ",", 
        RowBox[{"\"\<PNOrder\>\"", "\[Rule]", "pnOrder"}], ",", 
        RowBox[{"\"\<RootDirectory\>\"", "\[Rule]", "root"}], ",", 
        RowBox[{
        "\"\<ParabolicVelocitySign\>\"", "\[Rule]", 
         "parabolicVelocitySign"}]}], "]"}]}]}], "]"}]}], ";", 
  RowBox[{
   RowBox[{"computeQKPN", "[", 
    RowBox[{
    "modelName_String", ",", "initialData_Association", ",", "times_List", 
     ",", "order_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "model", "}"}], ",", 
     RowBox[{
      RowBox[{"model", "=", 
       RowBox[{"QKOrbits`QKLoadModel", "[", 
        RowBox[{"modelName", ",", 
         RowBox[{"\"\<RootDirectory\>\"", "\[Rule]", "root"}]}], "]"}]}], ";", 
      RowBox[{"QKOrbits`QKOrbitFromInitialData", "[", 
       RowBox[{
       "model", ",", "primitiveParams", ",", "initialData", ",", "times", ",", 
        RowBox[{"WorkingPrecision", "\[Rule]", "wp"}], ",", 
        RowBox[{"AccuracyGoal", "\[Rule]", "accGoal"}], ",", 
        RowBox[{"PrecisionGoal", "\[Rule]", "precGoal"}], ",", 
        RowBox[{"\"\<PNOrder\>\"", "\[Rule]", "order"}], ",", 
        RowBox[{"\"\<RootDirectory\>\"", "\[Rule]", "root"}], ",", 
        RowBox[{
        "\"\<ParabolicVelocitySign\>\"", "\[Rule]", 
         "parabolicVelocitySign"}]}], "]"}]}]}], "]"}]}], ";", 
  RowBox[{
   RowBox[{"computeQK", "[", 
    RowBox[{
    "modelName_String", ",", "initialData_Association", ",", "times_List"}], 
    "]"}], ":=", 
   RowBox[{"computeQKPN", "[", 
    RowBox[{"modelName", ",", "initialData", ",", "times", ",", "pnOrder"}], 
    "]"}]}], ";", 
  RowBox[{
   RowBox[{"computeDirect", "[", 
    RowBox[{"initialData_Association", ",", "times_List"}], "]"}], ":=", 
   RowBox[{"DirectEOMOrbits`DirectEOMOrbit", "[", 
    RowBox[{
    "eom", ",", "primitiveParams", ",", "initialData", ",", "times", ",", 
     RowBox[{"WorkingPrecision", "\[Rule]", "directWP"}], ",", 
     RowBox[{"AccuracyGoal", "\[Rule]", "directAccGoal"}], ",", 
     RowBox[{"PrecisionGoal", "\[Rule]", "directPrecGoal"}], ",", 
     RowBox[{"\"\<PNOrder\>\"", "\[Rule]", "pnOrder"}], ",", 
     RowBox[{"MaxStepSize", "\[Rule]", "directMaxStepSize"}], ",", 
     RowBox[{
     "\"\<Include2p5PNRadiationReaction\>\"", "\[Rule]", "includeRR25"}]}], 
    "]"}]}], ";", 
  RowBox[{
   RowBox[{"orbitRows", "[", "orbit_Association", "]"}], ":=", 
   RowBox[{"Prepend", "[", 
    RowBox[{
     RowBox[{"Transpose", "[", 
      RowBox[{"orbit", "/@", 
       RowBox[{"{", 
        RowBox[{
        "\"\<t\>\"", ",", "\"\<r\>\"", ",", "\"\<phi\>\"", ",", 
         "\"\<rdot\>\"", ",", "\"\<phidot\>\""}], "}"}]}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{
      "\"\<t\>\"", ",", "\"\<r\>\"", ",", "\"\<phi\>\"", ",", "\"\<rdot\>\"", 
       ",", "\"\<phidot\>\""}], "}"}]}], "]"}]}], ";", 
  RowBox[{"directStyle", "=", 
   RowBox[{"Directive", "[", 
    RowBox[{
     TemplateBox[<|"color" -> RGBColor[0.08, 0.32, 0.78]|>,
      "RGBColorSwatchTemplate"], ",", 
     RowBox[{"AbsoluteThickness", "[", "2.4`", "]"}]}], "]"}]}], ";", 
  RowBox[{"qkStyle", "=", 
   RowBox[{"Directive", "[", 
    RowBox[{"Black", ",", "Dashed", ",", 
     RowBox[{"AbsoluteThickness", "[", "2.8`", "]"}]}], "]"}]}], ";", 
  RowBox[{"qk0Style", "=", 
   RowBox[{"Directive", "[", 
    RowBox[{
     TemplateBox[<|"color" -> RGBColor[0.85, 0.05, 0.05]|>,
      "RGBColorSwatchTemplate"], ",", 
     RowBox[{"AbsoluteThickness", "[", "2.1`", "]"}]}], "]"}]}], ";", 
  RowBox[{"otherStyle", "=", 
   RowBox[{"Directive", "[", 
    RowBox[{
     TemplateBox[<|"color" -> RGBColor[0.7, 0.12, 0.12]|>,
      "RGBColorSwatchTemplate"], ",", "DotDashed", ",", 
     RowBox[{"AbsoluteThickness", "[", "2.2`", "]"}]}], "]"}]}], ";", 
  RowBox[{"fields", "=", 
   RowBox[{"{", 
    RowBox[{
    "\"\<r\>\"", ",", "\"\<phi\>\"", ",", "\"\<rdot\>\"", ",", 
     "\"\<phidot\>\""}], "}"}]}], ";", 
  RowBox[{"fieldLabels", "=", 
   RowBox[{"Association", "[", 
    RowBox[{
     RowBox[{"\"\<r\>\"", "\[Rule]", "\"\<r / M\>\""}], ",", 
     RowBox[{"\"\<phi\>\"", "\[Rule]", "\"\<\[Phi]\>\""}], ",", 
     RowBox[{
     "\"\<rdot\>\"", "\[Rule]", 
      "\"\<\\!\\(\\*OverscriptBox[\\(r\\), \\(.\\)]\\)\>\""}], ",", 
     RowBox[{
     "\"\<phidot\>\"", "\[Rule]", 
      "\"\<M \\!\\(\\*OverscriptBox[\\(\[Phi]\\), \\(.\\)]\\)\>\""}]}], 
    "]"}]}], ";", 
  RowBox[{
   RowBox[{"directLabel", "[", "]"}], ":=", 
   RowBox[{"If", "[", 
    RowBox[{
    "includeRR25", ",", "\"\<direct EOM + 2.5PN RR\>\"", ",", 
     "\"\<direct EOM\>\""}], "]"}]}], ";", 
  RowBox[{
   RowBox[{"shortValue", "[", "x_", "]"}], ":=", 
   RowBox[{"If", "[", 
    RowBox[{
     RowBox[{"NumberQ", "[", 
      RowBox[{"N", "[", "x", "]"}], "]"}], ",", 
     RowBox[{"N", "[", 
      RowBox[{"x", ",", "16"}], "]"}], ",", "x"}], "]"}]}], ";", 
  RowBox[{
   RowBox[{"shortAssoc", "[", "a_Association", "]"}], ":=", 
   RowBox[{"AssociationMap", "[", 
    RowBox[{"shortValue", ",", "a"}], "]"}]}], ";", 
  RowBox[{
   RowBox[{"publicQKParameterKeys", "[", 
    RowBox[{"modelName_String", ",", "qkParams_Association"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "keys", "}"}], ",", 
     RowBox[{
      RowBox[{"keys", "=", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"StringContainsQ", "[", 
          RowBox[{"modelName", ",", "\"\<Parabolic\>\""}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"\"\<sP\>\"", ",", "\"\<rP\>\""}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{
          "\"\<n\>\"", ",", "\"\<K\>\"", ",", "\"\<ar\>\"", ",", "\"\<er\>\"",
            ",", "\"\<et\>\"", ",", "\"\<ePhi\>\"", ",", "\"\<fPhi\>\"", ",", 
           "\"\<gPhi\>\"", ",", "\"\<hPhi\>\"", ",", "\"\<iPhi\>\"", ",", 
           "\"\<gt\>\"", ",", "\"\<ft\>\"", ",", "\"\<ht\>\"", ",", 
           "\"\<it\>\""}], "}"}]}], "]"}]}], ";", 
      RowBox[{"Select", "[", 
       RowBox[{"keys", ",", 
        RowBox[{
         RowBox[{"KeyExistsQ", "[", 
          RowBox[{"qkParams", ",", "#1"}], "]"}], "&"}]}], "]"}]}]}], "]"}]}],
   ";", 
  RowBox[{
   RowBox[{"qkInfoDisplay", "[", 
    RowBox[{"modelName_String", ",", "info_Association"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"params", "=", 
        RowBox[{"info", "[", "\"\<QKParameters\>\"", "]"}]}], ",", "keys"}], 
      "}"}], ",", 
     RowBox[{
      RowBox[{"keys", "=", 
       RowBox[{"publicQKParameterKeys", "[", 
        RowBox[{"modelName", ",", "params"}], "]"}]}], ";", 
      RowBox[{"Association", "[", 
       RowBox[{
        RowBox[{"\"\<InitialData\>\"", "\[Rule]", 
         RowBox[{"shortAssoc", "[", 
          RowBox[{"info", "[", "\"\<InitialData\>\"", "]"}], "]"}]}], ",", 
        RowBox[{"\"\<InitialScales\>\"", "\[Rule]", 
         RowBox[{"shortAssoc", "[", 
          RowBox[{"info", "[", "\"\<InitialScales\>\"", "]"}], "]"}]}], ",", 
        RowBox[{"\"\<ConservedLabels\>\"", "\[Rule]", 
         RowBox[{"shortAssoc", "[", 
          RowBox[{"info", "[", "\"\<ConservedLabels\>\"", "]"}], "]"}]}], ",", 
        RowBox[{"\"\<QKParameters\>\"", "\[Rule]", 
         RowBox[{"shortAssoc", "[", 
          RowBox[{"KeyTake", "[", 
           RowBox[{"params", ",", "keys"}], "]"}], "]"}]}]}], "]"}]}]}], 
    "]"}]}], ";", 
  RowBox[{
   RowBox[{"styleFor", "[", "label_", "]"}], ":=", 
   RowBox[{"Which", "[", 
    RowBox[{
     RowBox[{"label", "===", "\"\<0PN QK\>\""}], ",", "qk0Style", ",", 
     RowBox[{"label", "===", "\"\<QK\>\""}], ",", "qkStyle", ",", 
     RowBox[{"StringContainsQ", "[", 
      RowBox[{"label", ",", "\"\<direct\>\""}], "]"}], ",", "directStyle", 
     ",", "True", ",", "otherStyle"}], "]"}]}], ";", 
  RowBox[{
   RowBox[{"realValues", "[", "x_", "]"}], ":=", 
   RowBox[{"Chop", "[", 
    RowBox[{"Re", "[", 
     RowBox[{"N", "[", "x", "]"}], "]"}], "]"}]}], ";", 
  RowBox[{
   RowBox[{"seriesPanel", "[", 
    RowBox[{"title_String", ",", "orbits_Association", ",", "field_String"}], 
    "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"names", ",", "t", ",", "vals", ",", "curves", ",", "yGrid"}], 
      "}"}], ",", 
     RowBox[{
      RowBox[{"names", "=", 
       RowBox[{"Keys", "[", "orbits", "]"}]}], ";", 
      RowBox[{"t", "=", 
       RowBox[{"realValues", "[", 
        RowBox[{
         RowBox[{"First", "[", 
          RowBox[{"Values", "[", "orbits", "]"}], "]"}], "[", "\"\<t\>\"", 
         "]"}], "]"}]}], ";", 
      RowBox[{"vals", "=", 
       RowBox[{"Join", "@@", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"realValues", "[", 
            RowBox[{"#1", "[", "field", "]"}], "]"}], "&"}], ")"}], "/@", 
         RowBox[{"Values", "[", "orbits", "]"}]}]}]}], ";", 
      RowBox[{"curves", "=", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"Transpose", "[", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"realValues", "[", 
              RowBox[{"#1", "[", "\"\<t\>\"", "]"}], "]"}], ",", 
             RowBox[{"realValues", "[", 
              RowBox[{"#1", "[", "field", "]"}], "]"}]}], "}"}], "]"}], "&"}],
          ")"}], "/@", 
        RowBox[{"Values", "[", "orbits", "]"}]}]}], ";", 
      RowBox[{"yGrid", "=", 
       RowBox[{"Subdivide", "[", 
        RowBox[{
         RowBox[{"Min", "[", "vals", "]"}], ",", 
         RowBox[{"Max", "[", "vals", "]"}], ",", "4"}], "]"}]}], ";", 
      RowBox[{"ListLinePlot", "[", 
       RowBox[{"curves", ",", 
        RowBox[{"PlotStyle", "\[Rule]", 
         RowBox[{"styleFor", "/@", "names"}]}], ",", 
        RowBox[{"Frame", "\[Rule]", "True"}], ",", 
        RowBox[{"FrameTicks", "\[Rule]", "Automatic"}], ",", 
        RowBox[{"FrameLabel", "\[Rule]", 
         RowBox[{"{", 
          RowBox[{"\"\<t / M\>\"", ",", 
           RowBox[{"fieldLabels", "[", "field", "]"}]}], "}"}]}], ",", 
        RowBox[{"PlotLabel", "\[Rule]", 
         RowBox[{"Style", "[", 
          RowBox[{
           RowBox[{"title", "<>", "\"\<  \>\"", "<>", 
            RowBox[{"fieldLabels", "[", "field", "]"}]}], ",", "15", ",", 
           "Bold", ",", "Black"}], "]"}]}], ",", 
        RowBox[{"GridLines", "\[Rule]", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Subdivide", "[", 
            RowBox[{
             RowBox[{"Min", "[", "t", "]"}], ",", 
             RowBox[{"Max", "[", "t", "]"}], ",", "4"}], "]"}], ",", 
           "yGrid"}], "}"}]}], ",", 
        RowBox[{"GridLinesStyle", "\[Rule]", 
         RowBox[{"Directive", "[", 
          RowBox[{
           TemplateBox[<|"color" -> GrayLevel[0.85]|>,
            "GrayLevelColorSwatchTemplate"], ",", 
           RowBox[{"AbsoluteThickness", "[", "0.6`", "]"}]}], "]"}]}], ",", 
        RowBox[{"AspectRatio", "\[Rule]", "0.62`"}], ",", 
        RowBox[{"ImageSize", "\[Rule]", "360"}], ",", 
        RowBox[{"ImagePadding", "\[Rule]", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"86", ",", "24"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"58", ",", "30"}], "}"}]}], "}"}]}], ",", 
        RowBox[{"BaseStyle", "\[Rule]", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"FontFamily", "\[Rule]", "\"\<Arial\>\""}], ",", 
           RowBox[{"FontSize", "\[Rule]", "12"}], ",", "Black"}], "}"}]}], 
        ",", 
        RowBox[{"LabelStyle", "\[Rule]", 
         RowBox[{"{", 
          RowBox[{"Black", ",", "13"}], "}"}]}], ",", 
        RowBox[{"FrameTicksStyle", "\[Rule]", 
         RowBox[{"Directive", "[", 
          RowBox[{"Black", ",", "11"}], "]"}]}], ",", 
        RowBox[{"PlotRange", "\[Rule]", "All"}], ",", 
        RowBox[{"PlotRangePadding", "\[Rule]", 
         RowBox[{"Scaled", "[", "0.05`", "]"}]}]}], "]"}]}]}], "]"}]}], ";", 
  RowBox[{
   RowBox[{"plotOrbit", "[", 
    RowBox[{"title_String", ",", "orbits_Association"}], "]"}], ":=", 
   RowBox[{"Legended", "[", 
    RowBox[{
     RowBox[{"GraphicsGrid", "[", 
      RowBox[{
       RowBox[{"Partition", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"seriesPanel", "[", 
             RowBox[{"title", ",", "orbits", ",", "#1"}], "]"}], "&"}], ")"}],
           "/@", "fields"}], ",", "2"}], "]"}], ",", 
       RowBox[{"Spacings", "\[Rule]", 
        RowBox[{"{", 
         RowBox[{"0.2`", ",", "0.25`"}], "}"}]}]}], "]"}], ",", 
     RowBox[{"Placed", "[", 
      RowBox[{
       RowBox[{"LineLegend", "[", 
        RowBox[{
         RowBox[{"styleFor", "/@", 
          RowBox[{"Keys", "[", "orbits", "]"}]}], ",", 
         RowBox[{"Keys", "[", "orbits", "]"}], ",", 
         RowBox[{"LegendLayout", "\[Rule]", "\"\<Row\>\""}], ",", 
         RowBox[{"LabelStyle", "\[Rule]", 
          RowBox[{"{", 
           RowBox[{"Black", ",", "14"}], "}"}]}], ",", 
         RowBox[{"LegendMarkerSize", "\[Rule]", "34"}]}], "]"}], ",", 
       "Below"}], "]"}]}], "]"}]}], ";", 
  RowBox[{
   RowBox[{"exportOrbit", "[", 
    RowBox[{
    "name_String", ",", "qkInfo_Association", ",", "qk_Association", ",", 
     "direct_Association", ",", "qkFig_", ",", "directFig_", ",", 
     "overlayFig_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"dir", "=", "outDir"}], "}"}], ",", 
     RowBox[{
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"!", 
         RowBox[{"DirectoryQ", "[", "dir", "]"}]}], ",", 
        RowBox[{"CreateDirectory", "[", 
         RowBox[{"dir", ",", 
          RowBox[{"CreateIntermediateDirectories", "\[Rule]", "True"}]}], 
         "]"}]}], "]"}], ";", 
      RowBox[{"Export", "[", 
       RowBox[{
        RowBox[{"FileNameJoin", "[", 
         RowBox[{"{", 
          RowBox[{"dir", ",", 
           RowBox[{"name", "<>", "\"\<_qk.png\>\""}]}], "}"}], "]"}], ",", 
        "qkFig", ",", 
        RowBox[{"ImageResolution", "\[Rule]", "170"}]}], "]"}], ";", 
      RowBox[{"Export", "[", 
       RowBox[{
        RowBox[{"FileNameJoin", "[", 
         RowBox[{"{", 
          RowBox[{"dir", ",", 
           RowBox[{"name", "<>", "\"\<_direct.png\>\""}]}], "}"}], "]"}], ",",
         "directFig", ",", 
        RowBox[{"ImageResolution", "\[Rule]", "170"}]}], "]"}], ";", 
      RowBox[{"Export", "[", 
       RowBox[{
        RowBox[{"FileNameJoin", "[", 
         RowBox[{"{", 
          RowBox[{"dir", ",", 
           RowBox[{"name", "<>", "\"\<_overlay.png\>\""}]}], "}"}], "]"}], 
        ",", "overlayFig", ",", 
        RowBox[{"ImageResolution", "\[Rule]", "170"}]}], "]"}], ";", 
      RowBox[{"Export", "[", 
       RowBox[{
        RowBox[{"FileNameJoin", "[", 
         RowBox[{"{", 
          RowBox[{"dir", ",", 
           RowBox[{"name", "<>", "\"\<_qk.tsv\>\""}]}], "}"}], "]"}], ",", 
        RowBox[{"orbitRows", "[", "qk", "]"}], ",", "\"\<TSV\>\""}], "]"}], 
      ";", 
      RowBox[{"Export", "[", 
       RowBox[{
        RowBox[{"FileNameJoin", "[", 
         RowBox[{"{", 
          RowBox[{"dir", ",", 
           RowBox[{"name", "<>", "\"\<_direct.tsv\>\""}]}], "}"}], "]"}], ",", 
        RowBox[{"orbitRows", "[", "direct", "]"}], ",", "\"\<TSV\>\""}], 
       "]"}], ";", 
      RowBox[{"qkInfo", ">>", 
       InterpretationBox[
        RowBox[{"FileNameJoin", "[", 
         RowBox[{"{", 
          RowBox[{"dir", ",", 
           RowBox[{"name", "<>", "\"\<_qk_parameters.wl\>\""}]}], "}"}], "]"}],
        FileNameJoin[{$CellContext`dir, $CellContext`name <> 
          "_qk_parameters.wl"}],
        Editable->False]}], ";", "dir"}]}], "]"}]}], ";"}]], "Input",Expressio\
nUUID->"a56b2d00-f9ef-574b-bc71-a8da48a456d1"]
}, Closed]],

Cell["Global Inputs", "Section",ExpressionUUID->"09dd31ff-1a5a-be43-97d3-cb31409ac08e"],

Cell["\<\
PNOrder must be one of allowedPNOrders. Use eps -> 1 for physical orbits; \
smaller eps values are bookkeeping diagnostics only and are not the PN \
truncation switch. includeRR25 affects only the direct EOM trajectory. \
parabolicVelocitySign chooses the sign of the missing parabolic velocity. \
directWP, directAccGoal, directPrecGoal, and directMaxStepSize control only \
the direct EOM solver.\
\>", "Text",ExpressionUUID->"f201103f-db9b-5c4f-b58f-c56b5c6efeeb"],

Cell[BoxData[
 RowBox[{
  RowBox[{"allowedPNOrders", "=", 
   RowBox[{"QKOrbits`QKAllowedPNOrders", "[", "]"}]}], ";", 
  RowBox[{"pnOrder", "=", "3"}], ";", 
  RowBox[{"includeRR25", "=", "False"}], ";", 
  RowBox[{"parabolicVelocitySign", "=", "1"}], ";", 
  RowBox[{"wp", "=", "MachinePrecision"}], ";", 
  RowBox[{"accGoal", "=", "Automatic"}], ";", 
  RowBox[{"precGoal", "=", "Automatic"}], ";", 
  RowBox[{"directWP", "=", "40"}], ";", 
  RowBox[{"directAccGoal", "=", "20"}], ";", 
  RowBox[{"directPrecGoal", "=", "20"}], ";", 
  RowBox[{"directMaxStepSize", "=", "500"}], ";", 
  RowBox[{"primitiveParams", "=", 
   RowBox[{"Association", "[", 
    RowBox[{
     RowBox[{"\"\<eps\>\"", "\[Rule]", "1"}], ",", 
     RowBox[{"\"\<nu\>\"", "\[Rule]", 
      FractionBox["21", "100"]}], ",", 
